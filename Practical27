import javax.swing.*;
import java.awt.*;
import java.awt.event.*;
public class Practical27 extends JFrame implements ActionListener{
	
	JLabel l1,l2,l3;
	JTextField t1,t2,t3;
	JButton btn;
	Practical27(){
		l1 = new JLabel("name : ");
		l2 = new JLabel("emp no : ");
		l3 = new JLabel("salary : ");
		
		t1 = new JTextField(15);
		t2 = new JTextField(15);
		t3 = new JTextField(15);
		
		btn = new JButton("submit");
		btn.addActionListener(this);
		
		setLayout(new GridLayout(4,2));
		
		add(l1);
		add(t1);
		add(l2);
		add(t2);
		add(l3);
		add(t3);
		add(btn);
		
		setSize(400,300);
		setDefaultCloseOperation(JFrame.EXIT_ON_CLOSE);
		setVisible(true);
	}
public void actionPerformed(ActionEvent e) {
	
	String name = t1.getText();
	String empno = t2.getText();
	String salary = t3.getText();
	
	new displayframe(empno,name,salary);
  }
public static void main(String[] args) {
	new Practical27();
}
}
class displayframe extends JFrame{
	 public displayframe(String emp,String nam,String sal){
		JLabel empno = new JLabel("empnumber : "+emp);
		JLabel name = new JLabel("name : "+nam);
		JLabel salary = new JLabel("salary : "+sal);
		
		setLayout(new GridLayout(3,1));
		
		add(empno);
		add(name);
		add(salary);
		
		setSize(400,200);
		setLocation(500,200);
		setDefaultCloseOperation(JFrame.DISPOSE_ON_CLOSE);
		setVisible(true);
	}
}
